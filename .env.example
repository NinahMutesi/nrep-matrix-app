# Appwrite endpoint for your project. For Appwrite Cloud this is usually
# https://cloud.appwrite.io/v1 — check Project Settings in the console.
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1

# Project Settings > Project ID
NEXT_PUBLIC_APPWRITE_PROJECT_ID=

# API Keys (server-side, NEVER expose to the browser) — create one under
# Project Settings > API Keys with scopes: databases.read/write,
# storage.read/write, teams.read/write, users.read/write
APPWRITE_API_KEY=
